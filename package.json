{
  "name": "netmonitor",
  "version": "0.1.0",
  "description": "Windows 桌面网络流量监控工具",
  "main": "dist/electron/main.js",
  "type": "commonjs",
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:electron\"",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:electron": "wait-on http://localhost:3000 && tsc -p electron/tsconfig.json && electron .",
    "build:frontend": "cd frontend && npm run build",
    "build:electron": "tsc -p electron/tsconfig.json",
    "prebuild": "node -e \"try{require('fs').unlinkSync('dist/package.json')}catch(e){}\"",
    "build": "npm run build:frontend && npm run build:electron && electron-builder",
    "preview": "electron ."
  },
  "dependencies": {
    "electron-is-dev": "^3.0.1"
  },
  "devDependencies": {
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1",
    "typescript": "^5.3.3",
    "@types/node": "^20.10.6",
    "concurrently": "^8.2.2",
    "wait-on": "^7.2.0"
  }
}
